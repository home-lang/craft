#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
CRAFT_BIN="$ROOT_DIR/packages/zig/zig-out/bin/craft"

if [ ! -x "$CRAFT_BIN" ]; then
  printf 'Craft binary is not built at %s\n' "$CRAFT_BIN" >&2
  printf 'Run `bun run build:core` from %s, then try again.\n' "$ROOT_DIR" >&2
  exit 127
fi

exec "$CRAFT_BIN" "$@"

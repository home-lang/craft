<?xml version="1.0" encoding="UTF-8"?>
<!--
  Distribution entitlements for the Craft binary shipped to end users.

  We deliberately request the *minimum* set of capabilities here — the dev
  plist (`entitlements-dev.plist`) is what disables the sandbox and library
  validation for local-iteration ergonomics. End users should never run with
  those flags turned off, since that disables the macOS exploit-mitigation
  story we otherwise rely on.

  If your app needs extra capabilities (camera, microphone, user-selected
  files, etc.), generate a custom plist via
  `generateEntitlements({ camera: true, ... })` from the SDK or fork this
  file in your own project.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Run inside the macOS app sandbox. -->
    <key>com.apple.security.app-sandbox</key>
    <true/>

    <!-- WebKit needs JIT for modern JS performance. Limited to the runtime
         WebView, not arbitrary code. -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>

    <!-- Allow outbound HTTP. Required for the auto-updater and fetch API. -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- Allow user-selected files (open dialog returns sandbox-scoped URLs). -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
</dict>
</plist>

{
  "name": "@craft-native/stx",
  "version": "0.0.4",
  "private": true,
  "type": "module",
  "description": "STX component library for Craft — signals, composables, and crosswind-styled UI primitives",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./composables": {
      "types": "./dist/composables/index.d.ts",
      "import": "./dist/composables/index.js"
    },
    "./directives": {
      "types": "./dist/directives/index.d.ts",
      "import": "./dist/directives/index.js"
    },
    "./styles": {
      "types": "./dist/styles.d.ts",
      "import": "./dist/styles.js"
    },
    "./router": {
      "types": "./dist/router/index.d.ts",
      "import": "./dist/router/index.js"
    },
    "./compiler": {
      "types": "./dist/compiler/index.d.ts",
      "import": "./dist/compiler/index.js"
    },
    "./crosswind.css": "./dist/crosswind.css"
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build.ts",
    "dev": "bun --watch src/index.ts"
  },
  "dependencies": {
    "@craft-native/craft": "workspace:*",
    "@cwcss/crosswind": "^0.1.6"
  },
  "devDependencies": {
    "better-dx": "^0.2.6"
  }
}
